{
  "title": "LLM Proxy — AI Gateway Overview",
  "uid": "llmproxy-overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["llmproxy", "ai-gateway"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(llmproxy_requests_total[1m]))",
          "legendFormat": "total"
        },
        {
          "expr": "sum by (path) (rate(llmproxy_requests_total[1m]))",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineWidth": 2}
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(llmproxy_requests_total{status=~\"5..\"}[1m])) / sum(rate(llmproxy_requests_total[1m])) * 100",
          "legendFormat": "5xx error rate"
        },
        {
          "expr": "sum(rate(llmproxy_requests_total{status=~\"4..\"}[1m])) / sum(rate(llmproxy_requests_total[1m])) * 100",
          "legendFormat": "4xx error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {"drawStyle": "line", "lineWidth": 2}
        }
      }
    },
    {
      "id": 3,
      "title": "Requests by Status Code",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (status) (rate(llmproxy_requests_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineWidth": 2, "stacking": {"mode": "normal"}}
        }
      }
    },
    {
      "id": 4,
      "title": "Active Requests",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "llmproxy_active_requests",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 5,
      "title": "Request Duration — p50 / p95 / p99 (s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(llmproxy_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(llmproxy_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(llmproxy_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineWidth": 2}
        }
      }
    },
    {
      "id": 6,
      "title": "Backend Duration by Model — p95 (s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(llmproxy_backend_duration_seconds_bucket[5m])))",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineWidth": 2}
        }
      }
    },
    {
      "id": 7,
      "title": "Backend Errors by Model (errors/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (model, error_type) (rate(llmproxy_backend_errors_total[1m]))",
          "legendFormat": "{{model}} — {{error_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"drawStyle": "line", "lineWidth": 2}
        }
      }
    },
    {
      "id": 8,
      "title": "Token Usage (tokens/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (model, type) (rate(llmproxy_tokens_total[1m]))",
          "legendFormat": "{{model}} — {{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {"drawStyle": "line", "lineWidth": 2, "stacking": {"mode": "normal"}}
        }
      }
    },
    {
      "id": 9,
      "title": "Total Tokens (cumulative)",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(llmproxy_tokens_total)",
          "legendFormat": "total tokens"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 10,
      "title": "Backend Request Rate by Model (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (model) (rate(llmproxy_backend_requests_total[1m]))",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineWidth": 2}
        }
      }
    }
  ]
}
